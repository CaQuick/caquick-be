{
  "name": "caquick-be",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:create": "prisma migrate dev --create-only",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "graphql:codegen": "graphql-codegen --config codegen.yml",
    "graphql:docs": "spectaql -c spectaql.yml",
    "prepare": "husky"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@nestjs/apollo": "13.2.5",
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "11.1.19",
    "@nestjs/graphql": "13.2.5",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.3.0",
    "@prisma/client": "^6.19.3",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "logform": "^2.7.0",
    "openid-client": "5.7.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "useragent": "^2.3.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.18.0",
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/typescript": "^5.0.10",
    "@graphql-codegen/typescript-resolvers": "^5.1.8",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "11.1.19",
    "@testcontainers/mysql": "^11.14.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^29",
    "@types/node": "^22.10.7",
    "@types/passport": "^1",
    "@types/passport-jwt": "^4",
    "@types/supertest": "^7.2.0",
    "@types/useragent": "^2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^29",
    "lint-staged": "^16.4.0",
    "mysql2": "^3.22.1",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "source-map-support": "^0.5.21",
    "spectaql": "^3.0.9",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "ts-jest": "^29",
    "ts-loader": "^9.5.7",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/index.ts",
      "!**/main.ts",
      "!**/*.module.ts",
      "!**/*.d.ts",
      "!**/graphql/graphql.types.ts",
      "!**/config/**",
      "!test/**"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 70,
        "branches": 58,
        "functions": 58,
        "lines": 70
      }
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "globalSetup": "<rootDir>/test/jest.global-setup.ts",
    "globalTeardown": "<rootDir>/test/jest.global-teardown.ts",
    "testTimeout": 60000,
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "packageManager": "yarn@4.9.4"
}
